# Backend origin (no trailing path). Used for Next rewrites and as default browser API base.
BACKEND_API_ORIGIN=http://110.225.254.51:5050

# Browser API base (inlined via next.config). If unset, defaults to ${BACKEND_API_ORIGIN}/api/v1.
# Use /api/v1 to call localhost and proxy to BACKEND_API_ORIGIN (no CORS on the API).
# NEXT_PUBLIC_API_URL=http://110.225.254.51:5050/api/v1
# NEXT_PUBLIC_API_URL=/api/v1
