# Copy to .env.local (never commit .env.local)

# Backend used by Next.js rewrites: /api/v1/* -> BACKEND_API_ORIGIN/api/v1/*
BACKEND_API_ORIGIN=http://110.225.254.51:5050

# Optional: force API base for the browser. In development, leaving this unset uses
# same-origin "/api/v1" so http://192.168.x.x:3000 on your LAN works correctly.
# NEXT_PUBLIC_API_URL=http://110.225.254.51:5050/api/v1
